{
  "buildCommand": "",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "https://weak-production.up.railway.app/static/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://weak-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
